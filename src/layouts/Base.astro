---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  math?: boolean;
}

const { title, description = 'Hongyu Su — PhD in Machine Learning, data scientist, researcher, engineer.', math = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" href="/images/hongyu_su.jpg" type="image/jpeg" />
    <title>{title} &mdash; Hongyu Su</title>
    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-HSNQ1ZDBH2"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HSNQ1ZDBH2');
    </script>

    {math && (
      <script is:inline id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    )}
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <div class="cursor-trail" aria-hidden="true"></div>
    <div class="site">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <script src="../scripts/main.ts"></script>
  </body>
</html>

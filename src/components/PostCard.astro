---
interface Props {
  title: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, date, slug, tags = [] } = Astro.props;
const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}/`} class="post-card fadein">
  <span class="date">{formatted}</span>
  <span class="title">{title}</span>
  {tags.length > 0 && (
    <div class="tags">
      {tags.slice(0, 3).map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  )}
</a>
